# Triton model config — Time Probability (Session Probability)
# Python Backend — serves LightGBM sklearn pipeline with JSON I/O

name: "time_probability"
backend: "python"
max_batch_size: 64
version_policy: { specific: { versions: [1] } }

input [
  {
    name: "json_input"
    data_type: TYPE_STRING
    dims: [-1]
  }
]

output [
  {
    name: "p_profitable"
    data_type: TYPE_FP32
    dims: [-1]
  },
  {
    name: "confidence"
    data_type: TYPE_FP32
    dims: [-1]
  },
  {
    name: "current_bucket"
    data_type: TYPE_STRING
    dims: [-1]
  },
  {
    name: "recommendation"
    data_type: TYPE_STRING
    dims: [-1]
  }
]

instance_group [{ count: 1  kind: KIND_CPU }]

dynamic_batching {
  preferred_batch_size: [1, 8, 16, 32, 64]
  max_queue_delay_microseconds: 2000
}

parameters {
  key: "EXECUTE_TIMEOUT"
  value: { string_value: "10" }
}

strict_model_config: false
