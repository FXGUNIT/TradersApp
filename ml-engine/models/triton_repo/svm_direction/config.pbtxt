# Triton model config — SVM Direction Classifier
name: "svm_direction"
platform: "onnxruntime_onnx"
max_batch_size: 64
version_policy: { specific: { versions: [1] } }

input [
  { name: "input"  data_type: TYPE_FP32  dims: [44] }
]
output [
  { name: "prob_long"   data_type: TYPE_FP32  dims: [-1] },
  { name: "prob_short"  data_type: TYPE_FP32  dims: [-1] },
  { name: "confidence"  data_type: TYPE_FP32  dims: [-1] },
  { name: "signal"      data_type: TYPE_STRING dims: [-1] }
]

instance_group [{ count: 1  kind: KIND_GPU  gpus: [0] }]
dynamic_batching { preferred_batch_size: [1, 4, 8, 16, 32]  max_queue_delay_microseconds: 5000 }
optimization { input_pinned_memory { enable: true }  output_pinned_memory { enable: true } }
strict_model_config: false
