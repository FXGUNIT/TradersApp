
# SQLite databases (generated at runtime)
*.db
*.db-shm
*.db-wal

# DVC cache and storage (large binary cache)
.dvc/cache/
.dvc/tmp/
.dvc/plots/

# Python bytecode (never commit compiled .pyc files)
__pycache__/
*.py[cod]
*.cpython-*.pyc
.pytest_cache/

# ML model backups (large, generated at runtime)
model_backups/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
artifacts
*.local
.env
.env.cicd
.env.local
.env.*.local
.env.codespaces
bff/.env
bff/.env.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Special Windows files
nul
airflow/reports/*.json
