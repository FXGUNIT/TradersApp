# ─────────────────────────────────────────────────────────────
# TradersApp — Codespaces Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy to .env.codespaces and fill in values.
# This file is auto-loaded by post-start.sh.
# Better: set these as GitHub Codespace Secrets (repo settings).
# ─────────────────────────────────────────────────────────────

# MLflow (only used with --profile mlops)
# MLFLOW_TRACKING_URI=http://localhost:5000

# Postgres (only used with full docker-compose.yml, not dev)
# POSTGRES_PASSWORD=

# MinIO (only used with full docker-compose.yml, not dev)
# MINIO_PASSWORD=

# Grafana (only used with --profile observability)
# GRAFANA_PASSWORD=
