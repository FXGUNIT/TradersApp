# TradersApp — Codespaces Environment Variables Template
#
# Copy this file to .env in the repo root:
#   cp .devcontainer/.env.codespaces.example .env
#
# REAL secrets (do NOT commit .env to git):
#   - MLFLOW_TRACKING_URI  — only if you want MLflow to persist to an external server
#   - Any BFF/ML engine API keys
#
# For local development (Docker Compose):
#   All services use SQLite + local bind mounts. No external services required.
#   MLFLOW_TRACKING_URI can be left empty.

# MLflow: leave empty for local SQLite backend (no MinIO/Postgres needed)
MLFLOW_TRACKING_URI=

# Optional: point at a real MLflow server if you want cloud persistence
# MLFLOW_TRACKING_URI=http://mlflow.example.com

# MLflow artifact root: local filesystem (handled by docker-compose mlops profile)
# No S3/MinIO needed for dev/Codespaces.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
