<Window x:Class="TradersApp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="TradersApp Desktop"
        Height="900"
        Width="1440"
        MinHeight="720"
        MinWidth="1280"
        Background="#0D1118"
        Loaded="Window_OnLoaded"
        KeyDown="Window_OnKeyDown">
    <Grid>
        <wv2:WebView2 x:Name="AppWebView" />
        <Border x:Name="StatusBanner"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="16"
                Padding="14,10"
                Visibility="Collapsed"
                Background="#D8101824"
                BorderBrush="#435D7A"
                BorderThickness="1"
                CornerRadius="14">
            <StackPanel>
                <TextBlock x:Name="StatusTextBlock"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#F4F8FC" />
                <TextBlock Margin="0,4,0,0"
                           FontSize="11"
                           Foreground="#C9D5E4"
                           Text="Ctrl+Shift+U checks for updates. Ctrl+Shift+I installs a signed package." />
            </StackPanel>
        </Border>
        <Border x:Name="MissingAssetsPanel"
                Visibility="Collapsed"
                Background="#F51A1F2A">
            <Grid>
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="620"
                        Padding="28"
                        Background="#FF111723"
                        BorderBrush="#415776"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#F6FAFF"
                                   Text="Desktop bundle unavailable" />
                        <TextBlock Margin="0,14,0,0"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Foreground="#D3DEEA"
                                   Text="The packaged web client was not found or WebView2 could not be initialized. The thin desktop shell only hosts the already-built React bundle." />
                        <TextBlock x:Name="MissingAssetsTextBlock"
                                   Margin="0,14,0,0"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Foreground="#AFC1D7" />
                        <StackPanel Margin="0,22,0,0"
                                    Orientation="Horizontal">
                            <Button Width="120"
                                    Height="38"
                                    Margin="0,0,12,0"
                                    Click="RetryButton_OnClick"
                                    Content="Retry" />
                            <Button Width="160"
                                    Height="38"
                                    Margin="0,0,12,0"
                                    Click="CheckForUpdatesButton_OnClick"
                                    Content="Check for updates" />
                            <Button Width="160"
                                    Height="38"
                                    Click="InstallPackageButton_OnClick"
                                    Content="Install package" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
