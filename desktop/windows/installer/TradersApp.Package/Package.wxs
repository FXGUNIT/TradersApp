<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
      Id="TradersApp.Desktop.Package"
      Name="TradersApp Desktop"
      Manufacturer="TradersApp"
      Version="1.0.0.0"
      UpgradeCode="{0557D930-7954-45A2-92C9-16A473515B37}"
      Scope="perUserOrMachine">

    <SummaryInformation Description="TradersApp Desktop thin client" Manufacturer="TradersApp" />
    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <Property Id="ApplicationFolderName" Value="TradersApp Desktop" />
    <Property Id="WixAppFolder" Value="WixPerMachineFolder" />
    <Property Id="ARPURLINFOABOUT" Value="https://traders.app" />
    <Property Id="ARPNOREPAIR" Value="0" />
    <Property Id="ARPNOMODIFY" Value="0" />

    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="APPLICATIONFOLDER" Name="TradersApp Desktop" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="TradersApp Desktop" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <ComponentGroup Id="ShellShortcuts">
      <Component Directory="ApplicationProgramsFolder" Guid="*">
        <Shortcut
            Id="StartMenuShortcut"
            Name="TradersApp Desktop"
            Description="Launch TradersApp Desktop"
            Target="[APPLICATIONFOLDER]TradersApp.Desktop.exe"
            WorkingDirectory="APPLICATIONFOLDER" />
        <Shortcut
            Id="UninstallShortcut"
            Name="Uninstall TradersApp Desktop"
            Target="[SystemFolder]msiexec.exe"
            Arguments="/x [ProductCode]" />
        <RemoveFolder Id="RemoveProgramsFolder" On="uninstall" />
        <RegistryValue
            Root="HKCU"
            Key="Software\TradersApp\Desktop"
            Name="ProgramsShortcut"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>

      <Component Directory="DesktopFolder" Guid="*">
        <Shortcut
            Id="DesktopShortcut"
            Name="TradersApp Desktop"
            Description="Launch TradersApp Desktop"
            Target="[APPLICATIONFOLDER]TradersApp.Desktop.exe"
            WorkingDirectory="APPLICATIONFOLDER" />
        <RegistryValue
            Root="HKCU"
            Key="Software\TradersApp\Desktop"
            Name="DesktopShortcut"
            Type="integer"
            Value="1"
            KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="MainFeature" Title="TradersApp Desktop" Level="1">
      <ComponentGroupRef Id="ShellShortcuts" />
      <Files Include="$(DesktopBuildDir)**" Directory="APPLICATIONFOLDER">
        <Exclude Files="**\*.pdb" />
      </Files>
    </Feature>

    <ui:WixUI Id="WixUI_Advanced" />
    <WixVariable Id="WixUILicenseRtf" Value="..\Assets\License.rtf" />
  </Package>
</Wix>
