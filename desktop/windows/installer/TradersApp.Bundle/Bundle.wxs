<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Bundle
      Name="TradersApp Desktop Setup"
      Manufacturer="TradersApp"
      Version="1.0.0.0"
      UpgradeCode="{0FBF4C0A-BB81-4613-B717-273978E6A4A0}"
      AboutUrl="https://traders.app"
      Compressed="yes">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          LicenseFile="..\Assets\License.rtf"
          Theme="rtfLicense"
          ShowVersion="yes" />
    </BootstrapperApplication>

    <util:RegistrySearch
        Id="WebView2MachineVersion"
        Variable="WebView2RuntimeMachineVersion"
        Root="HKLM"
        Key="SOFTWARE\WOW6432Node\Microsoft\EdgeUpdate\Clients\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}"
        Value="pv"
        Result="value"
        Bitness="always64" />

    <util:RegistrySearch
        Id="WebView2UserVersion"
        Variable="WebView2RuntimeUserVersion"
        Root="HKCU"
        Key="Software\Microsoft\EdgeUpdate\Clients\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}"
        Value="pv"
        Result="value" />

    <Chain>
      <?if $(HasWebView2Bootstrapper) = "True" ?>
      <ExePackage
          Id="WebView2Bootstrapper"
          DisplayName="Microsoft Edge WebView2 Runtime"
          DetectCondition="WebView2RuntimeMachineVersion OR WebView2RuntimeUserVersion"
          PerMachine="yes"
          Permanent="yes"
          Vital="yes"
          SourceFile="$(WebView2BootstrapperPath)"
          InstallArguments="/silent /install"
          RepairArguments="/silent /install" />
      <?endif ?>

      <MsiPackage
          Id="TradersAppDesktopMsi"
          SourceFile="TradersApp.Package.msi"
          Visible="no" />
    </Chain>
  </Bundle>
</Wix>
