# ═══════════════════════════════════════════════════════════════════════════════
# TRADERS APP — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# VITE_* vars are exposed to the frontend browser.
# Non-prefixed vars are server-only (BFF, ML Engine, Telegram Bridge).

# ─── Firebase ──────────────────────────────────────────────────────────────────
# Already configured in .env.local ✅ (traders-regiment project)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# ─── BFF URL (Frontend → BFF) ────────────────────────────────────────────────
# Local dev: leave empty (defaults to http://127.0.0.1:8788)
# Production: set to your Railway BFF URL, e.g. https://bff.tradersapp.com
VITE_BFF_URL=

# ─── AI Providers — All 7 Configured ✅ ─────────────────────────────────────
# Already set in .env.local: Gemini, Groq, OpenRouter (x2), Cerebras, DeepSeek, SambaNova
AI_GEMINI_PRO_KEY=
AI_GROQ_TURBO_KEY=
AI_OPENROUTER_MIND_ALPHA=
AI_OPENROUTER_MIND_BETA=
AI_CEREBRAS_KEY=
AI_DEEPSEEK_KEY=
AI_SAMBANOVA_KEY=

# ─── Telegram Notifications ────────────────────────────────────────────────────
# Get bot token: message @BotFather on Telegram → /newbot
# Get your Chat ID: message @userinfobot on Telegram
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=
VITE_TELEGRAM_BOT_USERNAME=   # Your bot's username, e.g. MyTraderBot (no @)

# ─── Breaking News Intelligence (100% Free) ───────────────────────────────────
# Finnhub: https://finnhub.io — free tier (60 req/min). Sign up, paste key.
# NewsData.io: https://newsdata.io — free tier (200 credits/month). Sign up.
FINNHUB_API_KEY=
NEWS_API_KEY=

# ─── ML Engine URL ─────────────────────────────────────────────────────────────
# Local dev: http://127.0.0.1:8001
# Production: your Railway ML Engine URL
ML_ENGINE_URL=http://127.0.0.1:8001

# ─── BFF Server Security ────────────────────────────────────────────────────────
BFF_ADMIN_PASS_HASH=    # Run: node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PASSWORD' + 'YOUR_SALT').digest('hex'))"
MASTER_SALT=             # Random 64-char hex string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BFF_HOST=127.0.0.1
BFF_PORT=8788
BFF_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ─── Telegram Bridge (Support Chat — port 5001) ───────────────────────────────
# Separate Express server. Set SERVICE_KEY to authenticate BFF → Bridge calls.
TELEGRAM_BRIDGE_PORT=5001
SUPPORT_SERVICE_KEY=     # Random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_BOT_MODE=polling   # 'polling' for dev, 'webhook' for production
TELEGRAM_ADMIN_CHAT_IDS=    # Comma-separated: 123456789,987654321

# ─── Feature Flags ──────────────────────────────────────────────────────────────
VITE_FEATURE_FLOATING_SUPPORT_CHAT=false
VITE_FEATURE_COLLECTIVE_CONSCIOUSNESS=false
VITE_FEATURE_MAIN_TERMINAL=false
VITE_FEATURE_CLEAN_ONBOARDING=false

# ─── Production Deployment (GitHub Actions / Railway / Vercel) ────────────────
# Fill these in AFTER setting up Railway + Vercel:
RAILWAY_TOKEN=
RAILWAY_ENVIRONMENT_ID=
RAILWAY_ML_SERVICE_ID=
RAILWAY_BFF_SERVICE_ID=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
CLOUDFLARE_BFF_HOSTNAME=
