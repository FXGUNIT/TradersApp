              }
            }}
            className="btn-glass"
            title="Open Tools Menu"
          >
            ðŸ› ï¸ TOOLS
          </button>
          
          {/* RULE #119: Notification Center Button */}
          <button 
            onClick={() => setNotificationCenterOpen(!notificationCenterOpen)}
