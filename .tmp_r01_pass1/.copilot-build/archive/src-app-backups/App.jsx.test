              background: notificationCenterOpen ? "rgba(0,122,255,0.2)" : "transparent", 
              border: `1px solid ${notificationCenterOpen ? "rgba(0,122,255,0.5)" : "rgba(255,255,255,0.2)"}`, 
              borderRadius: 6, 
              padding: "8px 12px", 
              cursor: "pointer", 
              color: notificationCenterOpen ? T.blue : T.muted, 
              fontFamily: T.font, 
              fontSize: 11, 
