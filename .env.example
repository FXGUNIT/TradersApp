# ============================================================================
# TRADERS APP - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# VITE_* vars are exposed to the frontend browser.
# Non-prefixed vars are server-only (BFF, ML Engine, Telegram Bridge).

# --- Firebase ---------------------------------------------------------------
# Already configured in .env.local (traders-regiment project)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# --- BFF URL (Frontend -> BFF) ---------------------------------------------
# Local dev: leave empty and use the Vite /api proxy.
# Pages-hosted frontends must set this explicitly; Cloudflare Pages does not
# provide the Vite proxy.
# Production example: https://bff.tradersapp.com
VITE_BFF_URL=

# --- Developer Root Proof Targets (Public Build Vars) -----------------------
# Optional build-time URLs for the Cloudflare Pages developer root landing.
# These are public browser-visible values, not secrets.
# In CI, prefer sourcing them from repository variables:
#   TRADERSAPP_DOMAIN
#   BFF_PUBLIC_HOST
#   API_PUBLIC_HOST
# Leave empty locally to use the baked-in sslip.io fallbacks.
VITE_PUBLIC_PROJECT_PREVIEW_URL=
VITE_PUBLIC_BFF_HEALTH_URL=
VITE_PUBLIC_API_HEALTH_URL=

# --- AI Providers -----------------------------------------------------------
AI_GEMINI_PRO_KEY=
AI_GROQ_TURBO_KEY=
AI_OPENROUTER_MIND_ALPHA=
AI_OPENROUTER_MIND_BETA=
AI_CEREBRAS_KEY=
AI_DEEPSEEK_KEY=
AI_SAMBANOVA_KEY=

# --- Breaking News Intelligence (100% Free) --------------------------------
FINNHUB_API_KEY=
NEWS_API_KEY=

# --- ML Engine URL ----------------------------------------------------------
# Local dev: http://127.0.0.1:8001
# Production: your deployed ML engine URL
ML_ENGINE_URL=http://127.0.0.1:8001

# --- BFF Server Security ----------------------------------------------------
BFF_ADMIN_PASS_HASH=    # Generate via: npm run admin:hash
MASTER_SALT=            # Optional custom salt for admin hash generation
BFF_HOST=127.0.0.1
BFF_PORT=8788
BFF_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://tradergunit.pages.dev
BFF_TELEGRAM_BOT_TOKEN=
BFF_TELEGRAM_CHAT_ID=

# --- Telegram Bridge (Support Chat - port 5001) -----------------------------
TELEGRAM_BRIDGE_PORT=5001
SUPPORT_SERVICE_KEY=
TELEGRAM_BOT_MODE=polling
TELEGRAM_ADMIN_CHAT_IDS=

# --- Feature Flags ----------------------------------------------------------
VITE_FEATURE_FLOATING_SUPPORT_CHAT=false
VITE_FEATURE_COLLECTIVE_CONSCIOUSNESS=false
VITE_FEATURE_MAIN_TERMINAL=false
VITE_FEATURE_CLEAN_ONBOARDING=false

# --- Production Deployment --------------------------------------------------
RAILWAY_TOKEN=
RAILWAY_ENVIRONMENT_ID=
RAILWAY_ML_SERVICE_ID=
RAILWAY_BFF_SERVICE_ID=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
CLOUDFLARE_BFF_HOSTNAME=
