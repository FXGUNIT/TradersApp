# ============================================================================
# TRADERS APP - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# VITE_* vars are exposed to the frontend browser.
# Non-prefixed vars are server-only (BFF, ML Engine, Telegram Bridge).

# --- Firebase ---------------------------------------------------------------
# Already configured in .env.local (traders-regiment project)

# Board Room storage:
# - auto/file uses durable local disk, safe for local dev and VPS mounted storage.
# - redis requires REDIS_URL or REDIS_HOST/REDIS_PORT to be reachable.
BOARD_ROOM_STORAGE_MODE=file
BOARD_ROOM_FALLBACK_STORE=board-room/fallback-store.json
SESSION_STORAGE_MODE=file
SESSION_FALLBACK_STORE=runtime/session-store.json
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# --- BFF URL (Frontend -> BFF) ---------------------------------------------
# Local dev: leave empty and use the Vite /api proxy.
# Pages-hosted frontends must set this explicitly; Cloudflare Pages does not
# provide the Vite proxy.
# Production example: https://bff.tradersapp.com
VITE_BFF_URL=

# --- Public Frontend Proof Targets (Public Build Vars) ----------------------
# Optional build-time URLs for the Cloudflare Pages public frontend contract.
# These are public browser-visible values, not secrets.
# In CI, prefer sourcing them from repository variables:
#   TRADERSAPP_DOMAIN
#   BFF_PUBLIC_HOST
#   API_PUBLIC_HOST
# `VITE_PROOF_*` is the primary contract.
# `VITE_PUBLIC_*` aliases are still supported for compatibility.
VITE_PROOF_FRONTEND=https://tradergunit.pages.dev/
VITE_PROOF_BFF=https://bff.173.249.18.14.sslip.io/health
VITE_PROOF_API=https://api.173.249.18.14.sslip.io/health
VITE_PUBLIC_BFF_BASE_URL=
VITE_DEVELOPER_PREVIEW_PATH=/developer
VITE_PUBLIC_PROJECT_PREVIEW_URL=
VITE_PUBLIC_BFF_HEALTH_URL=
VITE_PUBLIC_API_HEALTH_URL=

