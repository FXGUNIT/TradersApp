VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Server-only AI provider keys. Load these into the BFF, not the browser.
AI_GEMINI_PRO_KEY=
AI_GROQ_TURBO_KEY=
AI_OPENROUTER_MIND_ALPHA=
AI_OPENROUTER_MIND_BETA=
AI_CEREBRAS_KEY=
AI_DEEPSEEK_KEY=
AI_SAMBANOVA_KEY=

# Server-only notification keys.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional only when the frontend is not using the local Vite proxy.
VITE_BFF_URL=

# Feature flags. Set to "true" to enable a feature.
VITE_FEATURE_FLOATING_SUPPORT_CHAT=false
VITE_FEATURE_COLLECTIVE_CONSCIOUSNESS=false
VITE_FEATURE_MAIN_TERMINAL=false
VITE_FEATURE_CLEAN_ONBOARDING=false

# BFF / Infisical runtime secrets.
BFF_ADMIN_PASS_HASH=
MASTER_SALT=
BFF_HOST=127.0.0.1
BFF_PORT=8788
BFF_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
