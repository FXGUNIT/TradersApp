# --- ML Engine URL ----------------------------------------------------------
# Local dev: http://127.0.0.1:8001
# Production: your deployed ML engine URL
ML_ENGINE_URL=http://127.0.0.1:8001

# --- BFF Server Security ----------------------------------------------------
ADMIN_PASSWORD_LOGIN_ENABLED=false
ADMIN_MASTER_EMAIL=gunitsingh1994@gmail.com
ADMIN_MFA_EMAILS=gunitsingh1994@gmail.com,arkgproductions@gmail.com,starg.unit@gmail.com
ADMIN_TOTP_SECRET=
ADMIN_MFA_SECRET=
ADMIN_EMAILJS_SERVICE_ID=
ADMIN_EMAILJS_TEMPLATE_ID=
ADMIN_EMAILJS_PUBLIC_KEY=
ADMIN_EMAILJS_PRIVATE_KEY=
BFF_ADMIN_PASS_HASH=    # Legacy only; password login is disabled by default.
MASTER_SALT=            # Optional custom salt for legacy/admin MFA hashing.
BFF_HOST=127.0.0.1
BFF_PORT=8788
BFF_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://tradergunit.pages.dev
BFF_TELEGRAM_BOT_TOKEN=
BFF_TELEGRAM_CHAT_ID=

# --- Telegram Bridge (Support Chat - port 5001) -----------------------------
TELEGRAM_BRIDGE_PORT=5001
SUPPORT_SERVICE_KEY=
TELEGRAM_BOT_MODE=polling
TELEGRAM_ADMIN_CHAT_IDS=
TELEGRAM_ALLOWED_CHAT_IDS= # Optional: group/channel chat IDs where the bot should reply conversationally.
TELEGRAM_ALLOW_ALL_CHATS=false

# --- Feature Flags ----------------------------------------------------------
VITE_FEATURE_FLOATING_SUPPORT_CHAT=false
VITE_FEATURE_COLLECTIVE_CONSCIOUSNESS=false
VITE_FEATURE_MAIN_TERMINAL=false
VITE_FEATURE_CLEAN_ONBOARDING=false

# --- Production Deployment --------------------------------------------------
RAILWAY_TOKEN=
RAILWAY_ENVIRONMENT_ID=
RAILWAY_ML_SERVICE_ID=
RAILWAY_BFF_SERVICE_ID=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
CLOUDFLARE_BFF_HOSTNAME=
