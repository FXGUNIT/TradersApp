# Triton model config — AMD Classifier (Anomalous Diffusion Model phase prior)
# ONNX Runtime, GPU-accelerated, dynamic batching
# Model: sklearn.naive_bayes.GaussianNB + StandardScaler pipeline

name: "amd_direction"
platform: "onnxruntime_onnx"
max_batch_size: 64
version_policy: { specific: { versions: [1] } }

input [
  {
    name: "input"
    data_type: TYPE_FP32
    dims: [44]
    optional: false
  }
]

output [
  {
    name: "prob_long"
    data_type: TYPE_FP32
    dims: [-1]
  },
  {
    name: "prob_short"
    data_type: TYPE_FP32
    dims: [-1]
  },
  {
    name: "confidence"
    data_type: TYPE_FP32
    dims: [-1]
  },
  {
    name: "signal"
    data_type: TYPE_STRING
    dims: [-1]
  },
  {
    name: "amd_phase"
    data_type: TYPE_STRING
    dims: [-1]
  },
  {
    name: "amd_win_rate"
    data_type: TYPE_FP32
    dims: [-1]
  }
]

instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [0]
  }
]

# Dynamic batching — AMD model is fast, batch opportunistically
dynamic_batching {
  preferred_batch_size: [1, 4, 8, 16, 32, 64]
  max_queue_delay_microseconds: 2000
}

# Optimization
optimization {
  input_pinned_memory { enable: true }
  output_pinned_memory { enable: true }
  accelerator_deadline {
    format: TYPE_MS
    value: 30
  }
}

strict_model_config: false
