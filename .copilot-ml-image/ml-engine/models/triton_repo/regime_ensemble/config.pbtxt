# Triton model config — Regime Ensemble (Python Backend)
# Handles: HMM, FP-FK, Anomalous Diffusion, Regime Ensemble
# Uses Triton Python backend with JSON-serialized complex inputs

name: "regime_ensemble"
backend: "python"
max_batch_size: 32
version_policy: { specific: { versions: [1] } }

input [
  {
    name: "json_input"
    data_type: TYPE_STRING
    dims: [-1]
  }
]

output [
  {
    name: "regime"
    data_type: TYPE_STRING
    dims: [-1]
  },
  {
    name: "regime_id"
    data_type: TYPE_INT32
    dims: [-1]
  },
  {
    name: "confidence"
    data_type: TYPE_FP32
    dims: [-1]
  },
  {
    name: "deleverage_signal"
    data_type: TYPE_FP32
    dims: [-1]
  },
  {
    name: "stop_multiplier"
    data_type: TYPE_FP32
    dims: [-1]
  },
  {
    name: "signal_adjustment"
    data_type: TYPE_STRING
    dims: [-1]
  }
]

instance_group [
  {
    count: 1
    kind: KIND_CPU   # HMM/SciPy/PDE solvers don't benefit from GPU
  }
]

dynamic_batching {
  preferred_batch_size: [1, 4, 8, 16, 32]
  max_queue_delay_microseconds: 10000   # 10ms — regime changes are infrequent
}

# Python backend settings
parameters {
  key: "EXECUTE_TIMEOUT"
  value: { string_value: "30" }
}

strict_model_config: false
