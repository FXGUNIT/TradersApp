{
  "name": "ML Engine Pod Kill",
  "description": "Kill ML Engine pod and verify BFF gracefully degrades",
  "version": "1.0.0",
  "service": "ml-engine",
  "namespace": "tradersapp",
  "kind": "pod-kill",

  "steady-state-hypothesis": {
    "title": "ML Engine is healthy",
    "probes": [
      {
        "type": "http",
        "name": "ml-engine-health",
        "provider": {
          "type": "http",
          "url": "http://ml-engine:8001/health",
          "timeout": 5
        }
      },
      {
        "type": "http",
        "name": "bff-consensus",
        "provider": {
          "type": "http",
          "url": "http://bff:8788/api/consensus",
          "method": "POST",
          "body": {
            "symbol": "MNQ",
            "candles": [{"open": 18000, "high": 18002, "low": 17998, "close": 18001, "volume": 5000}],
            "session_id": 1
          },
          "timeout": 10
        }
      }
    ]
  },

  "method": [
    {
      "type": "action",
      "name": "kill-ml-engine-pod",
      "provider": {
        "type": "python",
        "module": "chaoskubernetes.pod.actions",
        "func": "kill_ml_engine_pods",
        "arguments": {
          "label_selector": "app=ml-engine",
          "duration": "60s"
        }
      }
    }
  ],

  "rollbacks": [
    {
      "type": "action",
      "name": "wait-for-recovery",
      "provider": {
        "type": "python",
        "module": "chaosk8s.watcher",
        "func": "wait_for_pods_ready",
        "arguments": {
          "label_selector": "app=ml-engine",
          "timeout": 120
        }
      }
    }
  ]
}
