    },
    {
      "title": "Prediction Latency (p99)",
      "description": "SLA target: <200ms. Amber: >200ms. Red: >500ms.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(ml_prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.2,
                "color": "yellow"
              },
              {
                "value": 0.5,
                "color": "red"
              }
            ]
          },
          "custom": {
            "displayMode": "color-background"
          }
        }
      }
    },
    {
      "title": "Prediction Latency (p50)",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 6,
        "y": 6
      },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.50, sum(rate(ml_prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 50,
                "color": "yellow"
              },
              {
                "value": 100,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "title": "Critical Path SLA (p95)",
      "description": "BFF /ml/consensus p95 latency. Target: under 50ms.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 10,
        "y": 6
      },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(bff_http_request_duration_seconds_bucket{route=\"/ml/consensus\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 50,
                "color": "yellow"
              },
              {
                "value": 100,
                "color": "red"
              }
            ]
          },
          "custom": {
            "displayMode": "color-background"
          }
        }
      }
    },
    {
      "title": "Cache Hit Ratio",
      "description": "Target: >80%. Cold cache after warmup = warning.",
      "type": "gauge",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 14,
        "y": 6
      },
      "targets": [
        {
          "expr": "ml_cache_hits_total / (ml_cache_hits_total + ml_cache_misses_total + 0.001)",
          "legendFormat": "hit ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 0.5,
                "color": "yellow"
              },
              {
                "value": 0.8,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "title": "System Health",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 18,
        "y": 6
      },
      "targets": [
        {
          "expr": "up{job=~\"ml-engine|bff|frontend\"} == 0",
          "legendFormat": "down services"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "ALL UP",
                  "color": "green"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 1,
                "to": 99,
                "result": {
                  "text": "DEGRADED",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        }
      }
    },
