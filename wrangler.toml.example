# Cloudflare Wrangler Config - optional free workers.dev experiments.
# Do not configure traders.app routes here; that domain is not owned.
# Used for managing Workers via CLI after Cloudflare auth is available.
#
# Install: npm install -g wrangler
# Auth:    npx wrangler login
# Deploy:  npx wrangler deploy
#
# DNS records and WAF rules are not part of the active no-owned-domain path.
# See deploy/cloudflare-tunnel/SETUP.md for the optional workers.dev proxy.

name = "traders-app"
main = "src/index.ts"
compatibility_date = "2026-04-24"
compatibility_flags = ["nodejs_compat"]
workers_dev = true

[vars]
ENVIRONMENT = "production"

# Secrets - set via:
# wrangler secret put BFF_URL
# wrangler secret put ML_ENGINE_URL
# DO NOT commit actual values here.

