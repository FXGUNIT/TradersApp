  DISTRIBUTION: { color: T.amdD, icon: "ГўвҖ”ЛҶ", label: "Distribution (Trend)", desc: "Smart money offloading into strength" },
  TRANSITION: { color: T.amdT, icon: "ГўЕёВі", label: "Transition (No Trade)", desc: "Phase shifting ГўвӮ¬вҖқ stay flat" },
  UNCLEAR: { color: T.muted, icon: "?", label: "Phase Unclear", desc: "No clear institutional signature" },
};

