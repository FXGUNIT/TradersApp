    "db:migrate:history": "python ml-engine/scripts/alembic_manage.py history",
    "db:migrate:baseline": "python ml-engine/scripts/alembic_manage.py stamp 20260415_000001",
    "db:migrate:new": "python ml-engine/scripts/new_migration.py",
    "db:migrate:alembic": "python ml-engine/scripts/alembic_manage.py",
    "test:performance": "node performanceTestRunner.js",
    "test:security": "node securityTestRunner.js",
    "test:leakage-prevention": "node leakagePreventionTestRunner.js",
    "test:social-engineering": "node socialEngineeringTestRunner.js",
    "test:fact-groundedness": "node factGroundednessTestRunner.js",
    "test:numerical-integrity": "node numericalIntegrityTestRunner.js",
    "test:context-window": "node contextWindowTestRunner.js"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "emailjs-com": "^3.2.0",
    "firebase": "^12.10.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tesseract.js": "^5.1.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^2.0.42",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "opencode-ai": "^1.14.29",
    "playwright-core": "^1.58.2",
    "sharp": "^0.34.5",
    "vite": "^8.0.0"
