{
  "name": "tradersapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "admin:hash": "node scripts/admin/generate-admin-pass-hash.mjs",
    "admin:mfa:totp": "node scripts/admin/admin-mfa-totp.mjs",
    "bff:dev": "node bff/server.mjs",
    "bff:dev:infisical": "infisical run -- node bff/server.mjs",
    "bff:dev:local": "node bff/server.mjs",
    "dev": "vite",
    "dev:infisical": "infisical run -- vite",
    "dev:local": "vite",
    "image:bff:hash": "node scripts/images/bff-image.mjs hash",
    "image:bff:build": "node scripts/images/bff-image.mjs build",
    "image:bff:smoke": "node scripts/images/bff-image.mjs smoke",
    "open": "powershell -ExecutionPolicy Bypass -File scripts/agents/open-cli.ps1 .",
    "open:infisical": "powershell -ExecutionPolicy Bypass -File scripts/agents/open-cli.ps1 .",
    "open:run": "powershell -ExecutionPolicy Bypass -File scripts/agents/open-cli.ps1 run",
    "open:run:infisical": "powershell -ExecutionPolicy Bypass -File scripts/agents/open-cli.ps1 run",
    "open:serve": "powershell -ExecutionPolicy Bypass -File scripts/agents/open-cli.ps1 serve --hostname 127.0.0.1 --port 4096",
    "open:serve:infisical": "powershell -ExecutionPolicy Bypass -File scripts/agents/open-cli.ps1 serve --hostname 127.0.0.1 --port 4096",
    "opencode": "powershell -ExecutionPolicy Bypass -File scripts/agents/open-cli.ps1 .",
    "build": "vite build",
    "build:desktop:web": "node scripts/windows/build-desktop-web.mjs",
    "lint": "eslint src vite.config.js eslint.config.js",
    "verify:ddd": "node scripts/architecture/verify-ddd-boundaries.mjs",
    "preview": "vite preview",
    "audit:ui": "node scripts/ui-audit/run-ui-audit.mjs",
    "audit:ui:mobile": "node scripts/ui-audit/run-ui-audit.mjs",
    "audit:website:user": "node scripts/website-audit/run-website-user-audit.mjs",
    "audit:website:user:live": "node scripts/website-audit/run-website-user-audit.mjs --live",
    "audit:website:user:summary": "node scripts/website-audit/summarize-website-user-audit.mjs",
