# Self-hosted Gitea + Woodpecker configuration
# Source of truth: Infisical.
# Recommended flow:
#   1. Store these keys in Infisical production.
#   2. Render `.env.cicd` from Infisical with:
#      powershell -ExecutionPolicy Bypass -File scripts/ci/render-cicd-env.ps1
# Docker Compose will ignore unrelated keys if your export contains more than this file.

GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222
GITEA_SSH_EXTERNAL_PORT=22
GITEA_UID=1000
GITEA_GID=1000
GITEA_DB_NAME=gitea
GITEA_DB_USER=gitea
GITEA_DB_PASSWORD=replace-with-a-long-random-password
GITEA_ADMIN_USERNAME=gitadmin
GITEA_ADMIN_PASSWORD=replace-with-a-long-random-password
GITEA_DOMAIN=git.example.com
GITEA_ROOT_URL=https://git.example.com/
GITEA_SSH_DOMAIN=git.example.com
GITEA_WEBHOOK_ALLOWED_HOST_LIST=external

WOODPECKER_PORT=8000
WOODPECKER_HOST=https://ci.example.com
WOODPECKER_ADMIN=gitadmin
WOODPECKER_REPO_OWNERS=gitadmin
WOODPECKER_GITEA_CLIENT=replace-with-gitea-oauth-client-id
WOODPECKER_GITEA_SECRET=replace-with-gitea-oauth-client-secret
WOODPECKER_GRPC_SECRET=replace-with-output-of-openssl-rand-hex-32
WOODPECKER_AGENT_SECRET=replace-with-output-of-openssl-rand-hex-32
WOODPECKER_AGENT_MAX_WORKFLOWS=2
