# Required deployment contract for the Contabo production path.
# Populate via GitHub secret CONTABO_APP_ENV or Infisical.
# Canonical public frontend: https://tradergunit.pages.dev/
# These host values are the Contabo runtime-edge proof surface, not the main
# public frontend URL.

GHCR_OWNER=fxgunit
IMAGE_TAG=latest
COMPOSE_PROJECT_NAME=tradersapp
TRADERSAPP_ROOT=/opt/tradersapp
TRADERSAPP_DOMAIN=173.249.18.14.sslip.io
BFF_PUBLIC_HOST=bff.173.249.18.14.sslip.io
API_PUBLIC_HOST=api.173.249.18.14.sslip.io
COMPOSE_PROFILES=core

NODE_ENV=production
BFF_HOST=0.0.0.0
BFF_PORT=8788
BFF_ALLOWED_ORIGINS=https://tradergunit.pages.dev,https://173.249.18.14.sslip.io,https://bff.173.249.18.14.sslip.io,https://api.173.249.18.14.sslip.io

REDIS_HOST=redis
REDIS_PORT=6379
BOARD_ROOM_STORAGE_MODE=file
BOARD_ROOM_FALLBACK_STORE=/app/board-room/fallback-store.json
SESSION_STORAGE_MODE=file
SESSION_FALLBACK_STORE=/app/runtime/session-store.json
ADMIN_PASSWORD_LOGIN_ENABLED=false
ADMIN_MASTER_EMAIL=gunitsingh1994@gmail.com
ADMIN_MFA_EMAILS=gunitsingh1994@gmail.com,arkgproductions@gmail.com,starg.unit@gmail.com
ADMIN_TOTP_SECRET=
ADMIN_MFA_SECRET=
ADMIN_EMAILJS_SERVICE_ID=
ADMIN_EMAILJS_TEMPLATE_ID=
ADMIN_EMAILJS_PUBLIC_KEY=
ADMIN_EMAILJS_PRIVATE_KEY=
ML_ENGINE_URL=http://ml-engine:8001
ML_HEALTH_TIMEOUT_MS=5000
ML_HEALTH_CACHE_TTL_MS=5000
ML_HEALTH_STALE_GRACE_MS=30000
PREDICT_SYNC_DQ_VALIDATION=false
ML_ANALYSIS_TRANSPORT=grpc
ML_ANALYSIS_GRPC_ADDR=analysis-service:50051
ML_ANALYSIS_GRPC_STRICT=false
ANALYSIS_SERVICE_GRPC_PORT=50051
ANALYSIS_SERVICE_HEALTH_PORT=8082
EDGE_SMOKE_STRICT=false

# Copy your existing production secrets below.
